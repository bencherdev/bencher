---
import {
	BENCHER_CHAT_URL,
	BENCHER_GITHUB_URL,
	BENCHER_LINKEDIN_URL,
	BENCHER_REDDIT_URL,
} from "../../util/ext";
import ThemeWordmark from "../navbar/theme/ThemeWordmark.astro";

const year = new Date().getFullYear();

const columns = [
	{
		label: "Product",
		links: [
			{ href: "/docs/", text: "Docs" },
			{ href: "/pricing/", text: "Pricing" },
			{ href: "/download/", text: "Download" },
		],
	},
	{
		label: "Learn",
		links: [
			{ href: "/learn/", text: "Learn" },
			{ href: "/docs/api/", text: "API" },
			{ href: "/docs/tutorial/bare-metal/", text: "Bare Metal" },
		],
	},
	{
		label: "Community",
		links: [
			{ href: "/explore/", text: "Explore" },
			{ href: "/perf/", text: "Public Projects" },
			{ href: "/play/", text: "Play" },
		],
	},
	{
		label: "Company",
		links: [
			{ href: "/help/", text: "Help" },
			{ href: "/brand/", text: "Brand" },
			{ href: "/legal/", text: "Legal" },
		],
	},
];

const finePrint = [
	{ href: "/legal/terms-of-use/", text: "Terms" },
	{ href: "/legal/privacy/", text: "Privacy" },
	{ href: "/legal/license/", text: "License" },
	{ href: "/sitemap-index.xml", text: "Sitemap" },
];

const socials = [
	{ href: BENCHER_GITHUB_URL, label: "GitHub", icon: "fa-github" },
	{ href: BENCHER_CHAT_URL, label: "Discord", icon: "fa-discord" },
	{ href: BENCHER_LINKEDIN_URL, label: "LinkedIn", icon: "fa-linkedin" },
	{ href: BENCHER_REDDIT_URL, label: "Reddit", icon: "fa-reddit-alien" },
];
---

<footer class="site-footer" data-pagefind-ignore="all">
	<div class="site-footer-inner">
		<div class="site-footer-top">
			<div class="site-footer-brand">
				<a class="site-footer-wordmark" title="🐰 Bencher" href="/">
					<ThemeWordmark />
				</a>
				<p class="site-footer-tagline">
					Catch performance regressions before they merge
				</p>
			</div>
			<nav class="site-footer-social" aria-label="Social links">
				{socials.map((s) => (
					<a
						class="site-footer-social-link"
						href={s.href}
						target="_blank"
						aria-label={s.label}
						rel="noreferrer"
					>
						<i class={`fab ${s.icon}`} aria-hidden="true"></i>
					</a>
				))}
			</nav>
		</div>

		<hr class="site-footer-rule" />

		<div class="site-footer-grid">
			{columns.map((col) => (
				<div class="site-footer-col">
					<div class="landing-eyebrow site-footer-eyebrow">{col.label}</div>
					<ul class="site-footer-links">
						{col.links.map((link) => (
							<li>
								<a href={link.href}>{link.text}</a>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>

		<hr class="site-footer-rule" />

		<div class="site-footer-fineprint">
			<p class="site-footer-copy">© {year} Bencher</p>
			<ul class="site-footer-fineprint-links">
				{finePrint.map((link) => (
					<li>
						<a href={link.href}>{link.text}</a>
					</li>
				))}
			</ul>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		padding: 4rem 1.5rem 2.5rem;
	}

	@media screen and (min-width: 769px) {
		.site-footer {
			padding: 5rem 2rem 2.5rem;
		}
	}

	@media screen and (min-width: 1024px) {
		.site-footer {
			padding: 5rem 4rem 3rem;
		}
	}

	@media screen and (min-width: 1216px) {
		.site-footer {
			padding: 5rem 6rem 3rem;
		}
	}

	.site-footer-inner {
		max-width: 1200px;
		margin: 0 auto;
	}

	.site-footer-top {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	@media screen and (min-width: 600px) {
		.site-footer-top {
			flex-direction: row;
			align-items: flex-start;
			justify-content: space-between;
			gap: 2rem;
		}
	}

	.site-footer-brand {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		max-width: 32rem;
	}

	.site-footer-wordmark {
		display: inline-flex;
		align-items: center;
		color: inherit;
	}

	.site-footer-tagline {
		margin: 0;
		color: var(--landing-muted);
		font-size: 0.95rem;
		line-height: 1.5;
	}

	.site-footer-social {
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}

	.site-footer-social-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--landing-muted);
		font-size: 1.25rem;
		line-height: 1;
		transition: color 0.15s ease;
	}

	.site-footer-social-link:hover,
	.site-footer-social-link:focus-visible {
		color: var(--brand-orange);
	}

	.site-footer-rule {
		border: 0;
		border-top: 1px solid var(--landing-card-border);
		margin: 2.5rem 0;
		height: 0;
	}

	.site-footer-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem 2rem;
	}

	@media screen and (min-width: 600px) {
		.site-footer-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media screen and (min-width: 900px) {
		.site-footer-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}

	.site-footer-col {
		display: flex;
		flex-direction: column;
	}

	.site-footer-eyebrow {
		margin-bottom: 1rem;
		text-transform: uppercase;
	}

	.site-footer-links {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.site-footer-links li {
		margin: 0;
	}

	.site-footer-links a {
		display: block;
		padding: 0.35rem 0;
		color: inherit;
		text-decoration: none;
		font-size: 0.95rem;
		transition: color 0.15s ease;
	}

	.site-footer-links a:hover,
	.site-footer-links a:focus-visible {
		color: var(--brand-orange);
	}

	.site-footer-fineprint {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		font-size: 0.85rem;
		color: var(--landing-muted);
	}

	@media screen and (min-width: 600px) {
		.site-footer-fineprint {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			gap: 1.5rem;
		}
	}

	.site-footer-copy {
		margin: 0;
	}

	.site-footer-fineprint-links {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem 1rem;
		align-items: center;
	}

	.site-footer-fineprint-links li {
		display: inline-flex;
		align-items: center;
	}

	.site-footer-fineprint-links li + li::before {
		content: "·";
		margin-right: 1rem;
		color: var(--landing-muted);
	}

	.site-footer-fineprint-links a {
		color: inherit;
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.site-footer-fineprint-links a:hover,
	.site-footer-fineprint-links a:focus-visible {
		color: var(--brand-orange);
	}
</style>
