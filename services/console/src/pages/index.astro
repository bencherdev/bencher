---
export const prerender = true;

import { IS_BENCHER_CLOUD } from "astro:env/client";

import BaseLayout from "../layouts/BaseLayout.astro";
import AuthRedirect from "../components/auth/AuthRedirect";
import SelfHostedRedirect from "../components/site/SelfHostedRedirct";
import { BENCHER_DESCRIPTION, BENCHER_TITLE } from "../util/resource";
import RegressionChart from "../components/landing/RegressionChart.astro";
import TrustedBy from "../components/landing/TrustedBy.astro";
import HowItWorks from "../components/landing/HowItWorks.astro";
import Showcase from "../components/landing/Showcase.astro";
import Toolbox from "../components/landing/Toolbox.astro";
import PRComment from "../components/landing/PRComment.astro";
import Customers from "../components/landing/Customers.astro";
import Hosting from "../components/landing/Hosting.astro";
import CallToAction from "../components/landing/CallToAction.astro";
---

<BaseLayout title={BENCHER_TITLE} description={BENCHER_DESCRIPTION}>
  <SelfHostedRedirect
    client:only="solid-js"
    isBencherCloud={IS_BENCHER_CLOUD}
    path="/console"
  />
  <AuthRedirect client:only="solid-js" path="/console" />
  <section class="hero-landing">
    <div class="columns">
      <div class="column is-10">
        <div class="content">
          <p class="hero-eyebrow">CONTINUOUS BENCHMARKING</p>
          <h1 class="title is-1">
            Catch performance regressions before they merge
          </h1>
          <h2 class="subtitle is-4">
            Bencher runs on bare metal to eliminate noise and deliver
            benchmark results you can actually trust.
          </h2>

          <div class="buttons">
            <a
              class="button is-primary is-medium is-responsive"
              href="/auth/signup"
            >
              Start benchmarking free
            </a>
            <a
              class="button is-medium is-responsive"
              href="/docs/tutorial/bare-metal/"
            >
              Read the docs
            </a>
          </div>
        </div>

        <div style="margin-top: 2rem;">
          <TrustedBy />
        </div>
      </div>
    </div>
  </section>

  <RegressionChart />

  <!-- https://bulma.io/documentation/helpers/spacing-helpers/ -->
  <section class="section p-3">
    <HowItWorks />

    <Showcase />

    <PRComment />

    <Toolbox />

    <Customers />

    <Hosting />

    <CallToAction />
  </section>
</BaseLayout>

<style>
  .hero-landing {
    padding: 4rem 1.5rem 2rem;
  }

  .hero-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: #888;
    margin-bottom: 1.5rem !important;
    padding-bottom: 0 !important;
    line-height: 1;
  }

  .hero-eyebrow + .title {
    margin-top: 0 !important;
  }

  @media screen and (min-width: 769px) {
    .hero-landing {
      padding: 6rem 4rem 2rem;
    }
  }

  @media screen and (min-width: 1024px) {
    .hero-landing {
      padding: 6rem 8rem 2rem;
    }
  }

  @media screen and (min-width: 1216px) {
    .hero-landing {
      padding: 6rem 12rem 2rem;
    }
  }
</style>
