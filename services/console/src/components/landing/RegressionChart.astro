---
// Animated SVG chart: steady → regression spike → alert → recovery
// Data points roughly model: ~5μs baseline, spike to ~22μs, recovery to ~5μs

const WIDTH = 800;
const HEIGHT = 320;
const PADDING = { top: 40, right: 40, bottom: 50, left: 60 };
const CHART_W = WIDTH - PADDING.left - PADDING.right;
const CHART_H = HEIGHT - PADDING.top - PADDING.bottom;

const dataPoints = [
  5.0, 5.2, 4.9, 5.1, 5.3, 4.8, 5.0, 5.1, // steady baseline
  22.0, // regression spike
  16.0, // boundary hit / alert point
  5.2, 5.0, // recovery
];

const yMin = 0;
const yMax = 25;
const boundaryY = 15;

const scaleX = (i: number) =>
  PADDING.left + (i / (dataPoints.length - 1)) * CHART_W;
const scaleY = (v: number) =>
  PADDING.top + CHART_H - ((v - yMin) / (yMax - yMin)) * CHART_H;

const linePoints = dataPoints
  .map((v, i) => `${scaleX(i)},${scaleY(v)}`)
  .join(" ");

const boundaryYPos = scaleY(boundaryY);

// Alert position at the spike (index 8)
const alertX = scaleX(8);
const alertY = scaleY(dataPoints[8]);

// Y-axis labels
const yLabels = [0, 5, 10, 15, 20, 25];

// Total animation duration
const drawDuration = 3;
const alertDelay = drawDuration * (8 / (dataPoints.length - 1));
const pauseDuration = 2.5;
const totalDuration = drawDuration + pauseDuration;

// Calculate polyline total length (approximate)
let totalLength = 0;
for (let i = 1; i < dataPoints.length; i++) {
  const dx = scaleX(i) - scaleX(i - 1);
  const dy = scaleY(dataPoints[i]) - scaleY(dataPoints[i - 1]);
  totalLength += Math.sqrt(dx * dx + dy * dy);
}
const strokeLen = Math.ceil(totalLength);
---

<section class="section" style="padding-top: 1rem; padding-bottom: 3rem;">
  <div class="columns is-centered">
    <div class="column is-three-quarters has-text-centered">
      <svg
        viewBox={`0 0 ${WIDTH} ${HEIGHT}`}
        class="regression-chart"
        role="img"
        aria-label="Animated chart showing benchmark results with a performance regression spike that triggers an alert, followed by recovery"
      >
        <!-- Background -->
        <rect width={WIDTH} height={HEIGHT} rx="12" fill="#1e1e1e" />

        <!-- Grid lines -->
        {yLabels.map((v) => (
          <line
            x1={PADDING.left}
            y1={scaleY(v)}
            x2={WIDTH - PADDING.right}
            y2={scaleY(v)}
            stroke="#333"
            stroke-width="0.5"
          />
        ))}

        <!-- Y-axis labels -->
        {yLabels.map((v) => (
          <text
            x={PADDING.left - 10}
            y={scaleY(v) + 4}
            text-anchor="end"
            fill="#888"
            font-size="11"
            font-family="system-ui, sans-serif"
          >
            {v}
          </text>
        ))}

        <!-- Y-axis title -->
        <text
          x="15"
          y={PADDING.top - 12}
          fill="#888"
          font-size="11"
          font-family="system-ui, sans-serif"
        >
          ↑ microseconds (μs)
        </text>

        <!-- Upper boundary (dashed) -->
        <line
          x1={PADDING.left}
          y1={boundaryYPos}
          x2={WIDTH - PADDING.right}
          y2={boundaryYPos}
          stroke="#e26000"
          stroke-width="1.5"
          stroke-dasharray="8,6"
          opacity="0.5"
          class="boundary-line"
        />

        <!-- Boundary label -->
        <text
          x={WIDTH - PADDING.right + 5}
          y={boundaryYPos + 4}
          fill="#e26000"
          font-size="10"
          font-family="system-ui, sans-serif"
          opacity="0.7"
        >
          limit
        </text>

        <!-- Data line (animated draw) -->
        <polyline
          points={linePoints}
          fill="none"
          stroke="#6bbfcf"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="data-line"
          style={`stroke-dasharray: ${strokeLen}; stroke-dashoffset: ${strokeLen};`}
        />

        <!-- Data points -->
        {dataPoints.map((v, i) => (
          <circle
            cx={scaleX(i)}
            cy={scaleY(v)}
            r="4"
            fill={i === 8 || i === 9 ? "#e26000" : "#6bbfcf"}
            class="data-point"
            style={`animation-delay: ${(i / (dataPoints.length - 1)) * drawDuration}s;`}
          />
        ))}

        <!-- Alert icon at spike -->
        <g class="alert-group" style={`animation-delay: ${alertDelay}s;`}>
          <!-- Alert background -->
          <circle
            cx={alertX}
            cy={alertY - 18}
            r="12"
            fill="#e26000"
            class="alert-pulse"
            style={`animation-delay: ${alertDelay}s;`}
          />
          <!-- Exclamation mark -->
          <text
            x={alertX}
            y={alertY - 14}
            text-anchor="middle"
            fill="white"
            font-size="16"
            font-weight="bold"
            font-family="system-ui, sans-serif"
            class="alert-icon"
            style={`animation-delay: ${alertDelay}s;`}
          >
            !
          </text>
        </g>
      </svg>
    </div>
  </div>
</section>

<style define:vars={{ strokeLen: String(strokeLen), drawDuration: `${drawDuration}s`, totalDuration: `${totalDuration}s`, alertDelay: `${alertDelay}s` }}>
  .regression-chart {
    width: 100%;
    max-width: 800px;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
  }

  .data-line {
    animation: draw-line var(--drawDuration) ease-out forwards;
    animation-iteration-count: infinite;
    animation-duration: var(--totalDuration);
  }

  @keyframes draw-line {
    0% {
      stroke-dashoffset: var(--strokeLen);
    }
    /* Line finishes drawing at drawDuration / totalDuration */
    54.5% {
      stroke-dashoffset: 0;
    }
    100% {
      stroke-dashoffset: 0;
    }
  }

  .data-point {
    opacity: 0;
    animation: fade-in 0.15s ease-out forwards;
    animation-iteration-count: infinite;
    animation-duration: var(--totalDuration);
  }

  @keyframes fade-in {
    0%, 3% {
      opacity: 0;
      transform: scale(0.5);
    }
    6%, 100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  .alert-group {
    opacity: 0;
    animation: alert-appear 0.3s ease-out forwards;
    animation-iteration-count: infinite;
    animation-duration: var(--totalDuration);
  }

  @keyframes alert-appear {
    0%, 38% {
      opacity: 0;
      transform: scale(0);
    }
    42% {
      opacity: 1;
      transform: scale(1.2);
    }
    46%, 100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  .alert-pulse {
    animation: pulse 1.5s ease-in-out infinite;
    animation-delay: var(--alertDelay);
    transform-origin: center;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.6;
    }
  }

  .boundary-line {
    animation: boundary-fade 0.5s ease-out forwards;
  }

  @keyframes boundary-fade {
    from {
      opacity: 0;
    }
    to {
      opacity: 0.5;
    }
  }
</style>
