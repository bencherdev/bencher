---
const alertRow = {
  benchmark: "Adapter::Json",
  measure: "Latency",
  units: "microseconds (µs)",
  result: "21.83",
  delta: "+336.60%",
  boundary: "15.00",
  limit: "145.53%",
};

const allRows = [
  {
    benchmark: "Adapter::Json",
    result: "21.83",
    delta: "+336.60%",
    boundary: "15.00",
    limit: "145.53%",
    alerted: true,
  },
  {
    benchmark: "Adapter::Magic (JSON)",
    result: "5.03",
    delta: "+0.60%",
    boundary: "6.00",
    limit: "83.83%",
  },
  {
    benchmark: "Adapter::Magic (Rust)",
    result: "4.98",
    delta: "-0.40%",
    boundary: "6.00",
    limit: "83.00%",
  },
  {
    benchmark: "Adapter::Rust",
    result: "5.02",
    delta: "+0.40%",
    boundary: "6.00",
    limit: "83.67%",
  },
  {
    benchmark: "Adapter::RustBench",
    result: "4.99",
    delta: "-0.20%",
    boundary: "6.00",
    limit: "83.17%",
  },
];
---

<section class="practice-section">
  <div class="columns is-centered">
    <div class="column is-10">
      <p class="practice-eyebrow">IN REVIEW</p>
      <h2 class="title is-1 practice-title">
        Catch performance regressions in code review, not in production
      </h2>
      <p class="subtitle is-5 practice-sub">
        No dashboards to remember to check. No manual benchmark runs. Every
        benchmark run lands as a PR comment. Regressions fail the build.
      </p>

      <div class="gh-wrap">
        <svg
          class="gh-svg"
          viewBox="0 0 1040 560"
          xmlns="http://www.w3.org/2000/svg"
          preserveAspectRatio="xMidYMin meet"
          role="img"
          aria-label="Example GitHub pull request comment from github-actions bot showing a Bencher Report with a performance regression alert"
        >
          <foreignObject x="0" y="0" width="1040" height="560">
            <div
              xmlns="http://www.w3.org/1999/xhtml"
              class="gh-comment"
            >
              <div class="gh-avatar" aria-hidden="true">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 16 16"
                  width="32"
                  height="32"
                >
                  <path
                    fill-rule="evenodd"
                    d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
                  ></path>
                </svg>
              </div>

              <div class="gh-card">
                <div class="gh-header">
                  <span class="gh-author">github-actions</span>
                  <span class="gh-bot-badge">bot</span>
                  <span class="gh-muted">
                    commented 1 day ago
                    <span class="gh-dot">·</span>
                    <span class="gh-edited">edited</span>
                    <span class="gh-caret">▾</span>
                  </span>
                  <span class="gh-kebab" aria-hidden="true">⋯</span>
                </div>

                <div class="gh-body">
                  <h3 class="gh-report-title">
                    <span class="gh-link">
                      <img
                        src="/favicon.svg"
                        width="26"
                        height="26"
                        alt=""
                        aria-hidden="true"
                      /><span>Bencher Report</span>
                    </span>
                  </h3>
                  <div class="gh-divider"></div>

                  <table class="gh-meta-table">
                    <tbody>
                      <tr>
                        <td>Branch</td>
                        <td><span class="gh-link">254/merge</span></td>
                      </tr>
                      <tr>
                        <td>Testbed</td>
                        <td><span class="gh-link">intel-v1</span></td>
                      </tr>
                    </tbody>
                  </table>

                  <blockquote class="gh-alert">
                    <strong>🚨 1 ALERT:</strong> Threshold Boundary Limit exceeded!
                  </blockquote>

                  <div class="gh-table-wrap">
                    <table class="gh-alert-table">
                      <thead>
                        <tr>
                          <th>Benchmark</th>
                          <th>Measure<br />Units</th>
                          <th>View</th>
                          <th>Benchmark Result<br />(Result Δ%)</th>
                          <th>Upper Boundary<br />(Limit %)</th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr>
                          <td><span class="gh-link">{alertRow.benchmark}</span></td>
                          <td>
                            <span class="gh-link">
                              {alertRow.measure}<br />{alertRow.units}
                            </span>
                          </td>
                          <td class="gh-view-cell">
                            📈 <span class="gh-link">plot</span><br />
                            🚨 <span class="gh-link">alert</span><br />
                            🚷 <span class="gh-link">threshold</span>
                          </td>
                          <td>
                            <b>{alertRow.result}<br />({alertRow.delta})</b>
                          </td>
                          <td>
                            <b>{alertRow.boundary}<br />({alertRow.limit})</b>
                          </td>
                        </tr>
                      </tbody>
                    </table>
                  </div>

                  <details class="gh-details">
                    <summary>Click to view all benchmark results</summary>
                    <div class="gh-table-wrap">
                      <table class="gh-alert-table">
                        <thead>
                          <tr>
                            <th>Benchmark</th>
                            <th><span class="gh-link">Latency</span></th>
                            <th>
                              Benchmark Results<br />microseconds (µs)<br />(Result Δ%)
                            </th>
                            <th>
                              Upper Boundary<br />microseconds (µs)<br />(Limit %)
                            </th>
                          </tr>
                        </thead>
                        <tbody>
                          {allRows.map((row) => (
                            <tr>
                              <td>
                                <span class="gh-link">{row.benchmark}</span>
                              </td>
                              <td class="gh-view-cell">
                                📈 <span class="gh-link">view plot</span><br />
                                {row.alerted && (
                                  <span>
                                    🚨 <span class="gh-link">view alert</span>
                                    <br />
                                  </span>
                                )}
                                🚷 <span class="gh-link">view threshold</span>
                              </td>
                              <td>
                                {row.alerted ? (
                                  <b>{row.result}<br />({row.delta})</b>
                                ) : (
                                  <>{row.result}<br />({row.delta})</>
                                )}
                              </td>
                              <td>
                                {row.alerted ? (
                                  <b>{row.boundary}<br />({row.limit})</b>
                                ) : (
                                  <>{row.boundary}<br />({row.limit})</>
                                )}
                              </td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  </details>

                  <p class="gh-full-link">
                    <span class="gh-link">
                      <img
                        src="/favicon.svg"
                        width="18"
                        height="18"
                        alt=""
                        aria-hidden="true"
                      />
                      View full continuous benchmarking report in Bencher
                    </span>
                  </p>
                </div>

                <div class="gh-reactions">
                  <span class="gh-reaction" aria-hidden="true">☺</span>
                </div>
              </div>
            </div>
          </foreignObject>
        </svg>
      </div>
    </div>
  </div>
</section>

<script>
  // Size the SVG wrapper to match the mock's actual content height so the
  // `<details>` expand/collapse doesn't leave empty space or clip.
  const mocks = document.querySelectorAll<SVGSVGElement>(".gh-svg");
  for (const svg of mocks) {
    const fo = svg.querySelector("foreignObject");
    const content = fo?.firstElementChild as HTMLElement | null;
    if (!fo || !content) continue;
    const update = () => {
      const h = Math.ceil(content.offsetHeight);
      if (!h) return;
      svg.setAttribute("viewBox", `0 0 1040 ${h}`);
      fo.setAttribute("height", String(h));
    };
    requestAnimationFrame(update);
    new ResizeObserver(update).observe(content);
  }
</script>

<style>
  .practice-section {
    padding: 1rem 1.5rem 4rem;
  }

  @media screen and (min-width: 769px) {
    .practice-section {
      padding: 1rem 2rem 5rem;
    }
  }

  @media screen and (min-width: 1024px) {
    .practice-section {
      padding: 1rem 4rem 5rem;
    }
  }

  @media screen and (min-width: 1216px) {
    .practice-section {
      padding: 1rem 6rem 5rem;
    }
  }

  .practice-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: #888;
    margin-bottom: 1.25rem;
    line-height: 1;
  }

  .practice-title {
    margin-bottom: 1.25rem !important;
  }

  .practice-sub {
    max-width: 720px;
    color: #666;
    margin-bottom: 2.5rem !important;
  }

  :global([data-theme="dark"]) .practice-sub {
    color: #a0a0a0;
  }

  /* ---------- GitHub comment mock (SVG wrapped) ---------- */

  .gh-wrap {
    --gh-bg: #ffffff;
    --gh-border: #d0d7de;
    --gh-text: #1f2328;
    --gh-muted: #59636e;
    --gh-link: #0969da;
    --gh-header-bg: #f6f8fa;
    --gh-alert-border: #fd8c73;
    --gh-alert-bg: #ffebe9;
    --gh-table-alt: #f6f8fa;
    --gh-avatar-bg: #1f2328;
    --gh-avatar-fg: #ffffff;
    --gh-badge-border: #d0d7de;
  }

  :global([data-theme="dark"]) .gh-wrap {
    --gh-bg: #0d1117;
    --gh-border: #30363d;
    --gh-text: #e6edf3;
    --gh-muted: #9198a1;
    --gh-link: #4493f8;
    --gh-header-bg: #151b23;
    --gh-alert-border: #f85149;
    --gh-alert-bg: #2a1215;
    --gh-table-alt: #151b23;
    --gh-avatar-bg: #ffffff;
    --gh-avatar-fg: #0d1117;
    --gh-badge-border: #3d444d;
  }

  .gh-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .gh-comment {
    display: flex;
    gap: 16px;
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans", Helvetica,
      Arial, sans-serif;
    font-size: 14px;
    line-height: 1.5;
    color: var(--gh-text);
    padding: 0;
  }

  .gh-avatar {
    flex: 0 0 40px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--gh-avatar-bg);
    color: var(--gh-avatar-fg);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .gh-avatar svg {
    fill: var(--gh-avatar-fg);
  }

  .gh-card {
    flex: 1;
    min-width: 0;
    position: relative;
    background: var(--gh-bg);
    border: 1px solid var(--gh-border);
    border-radius: 6px;
  }

  .gh-card::before,
  .gh-card::after {
    content: "";
    position: absolute;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .gh-card::before {
    left: -8px;
    top: 11px;
    border-top: 8px solid transparent;
    border-bottom: 8px solid transparent;
    border-right: 8px solid var(--gh-border);
  }

  .gh-card::after {
    left: -7px;
    top: 12px;
    border-top: 7px solid transparent;
    border-bottom: 7px solid transparent;
    border-right: 7px solid var(--gh-header-bg);
  }

  .gh-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    background: var(--gh-header-bg);
    border-bottom: 1px solid var(--gh-border);
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    font-size: 14px;
  }

  .gh-author {
    font-weight: 600;
    color: var(--gh-text);
  }

  .gh-bot-badge {
    font-size: 11px;
    font-weight: 500;
    padding: 0 6px;
    border: 1px solid var(--gh-badge-border);
    border-radius: 999px;
    color: var(--gh-muted);
    line-height: 18px;
  }

  .gh-muted {
    color: var(--gh-muted);
    font-size: 13px;
  }

  .gh-dot {
    margin: 0 4px;
  }

  .gh-edited {
    border-bottom: 1px dashed var(--gh-muted);
    cursor: default;
  }

  .gh-caret {
    margin-left: 2px;
  }

  .gh-kebab {
    margin-left: auto;
    color: var(--gh-muted);
    letter-spacing: 2px;
  }

  .gh-body {
    padding: 16px;
    color: var(--gh-text);
  }

  .gh-report-title {
    margin: 0 0 8px !important;
    line-height: 1.25;
  }

  .gh-report-title .gh-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--gh-link);
    font-size: 1.5em;
    font-weight: 600;
  }

  .gh-report-title img {
    display: inline-block;
    vertical-align: middle;
  }

  .gh-divider {
    height: 1px;
    background: var(--gh-border);
    margin: 8px 0 16px;
  }

  table.gh-meta-table,
  table.gh-alert-table {
    border-collapse: collapse;
    margin: 0 0 16px;
    display: block;
    max-width: 100%;
    overflow-x: auto;
  }

  .gh-meta-table td,
  .gh-alert-table th,
  .gh-alert-table td {
    border: 1px solid var(--gh-border);
    padding: 6px 13px;
    font-size: 14px;
  }

  .gh-alert-table th {
    background: var(--gh-header-bg);
    font-weight: 600;
    text-align: left;
  }

  .gh-alert-table tbody tr:nth-child(odd) td {
    background: var(--gh-table-alt);
  }

  .gh-meta-table tr:nth-child(2n) td {
    background: var(--gh-table-alt);
  }

  .gh-link {
    color: var(--gh-link);
    cursor: default;
  }

  .gh-view-cell {
    white-space: nowrap;
    line-height: 1.8;
  }

  .gh-alert {
    margin: 0 0 16px;
    padding: 8px 16px;
    border-left: 0.25em solid var(--gh-alert-border);
    background: var(--gh-alert-bg);
    color: var(--gh-text);
    font-size: 14px;
    border-radius: 0 6px 6px 0;
  }

  .gh-alert strong {
    font-weight: 600;
  }

  .gh-details {
    margin: 0 0 16px;
  }

  .gh-details summary {
    cursor: pointer;
    color: var(--gh-text);
    font-size: 14px;
    font-weight: 600;
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .gh-details summary::-webkit-details-marker {
    display: none;
  }

  .gh-details summary::before {
    content: "▶";
    display: inline-block;
    font-size: 10px;
    color: var(--gh-muted);
    transition: transform 0.15s ease;
    transform-origin: 45% 55%;
  }

  .gh-details[open] summary {
    margin-bottom: 12px;
  }

  .gh-details[open] summary::before {
    transform: rotate(90deg);
  }

  .gh-full-link {
    margin: 0 !important;
  }

  .gh-full-link .gh-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-weight: 600;
  }

  .gh-reactions {
    padding: 8px 16px;
    border-top: 1px solid var(--gh-border);
    border-bottom-left-radius: 6px;
    border-bottom-right-radius: 6px;
  }

  .gh-reaction {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: 1px solid var(--gh-border);
    border-radius: 999px;
    color: var(--gh-muted);
    font-size: 16px;
    background: var(--gh-bg);
  }

  @media screen and (max-width: 600px) {
    .gh-avatar {
      display: none;
    }
  }
</style>
