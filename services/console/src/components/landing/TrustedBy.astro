---
const LOGOS = [
  {
    name: "Google",
    src: "https://s3.us-east-1.amazonaws.com/public.bencher.dev/case-study/google.svg",
  },
  {
    name: "Microsoft",
    src: "https://s3.amazonaws.com/public.bencher.dev/case-study/microsoft.png",
  },
  {
    name: "GitLab",
    src: "https://s3.us-east-1.amazonaws.com/public.bencher.dev/case-study/gitlab.svg",
  },
  {
    name: "NVIDIA",
    src: "https://s3.us-east-1.amazonaws.com/public.bencher.dev/case-study/nvidia.svg",
  },
];
---

<div style="padding-top: 0; padding-bottom: 1rem;">
  <p class="trusted-by-label">TRUSTED BY ENGINEERING TEAMS AT</p>
  <div class="trusted-by-logos">
    {LOGOS.map((logo) => (
      <img
        class="trusted-by-logo"
        src={logo.src}
        alt={logo.name}
        loading="lazy"
      />
    ))}
  </div>
</div>

<style>
  .trusted-by-label {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: #888;
  }

  .trusted-by-logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    margin-top: 0.75rem;
  }

  .trusted-by-logo {
    height: 1.5rem;
    max-width: 6rem;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .trusted-by-logo:hover {
    opacity: 1;
  }
</style>
