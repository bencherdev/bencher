---
import { Language, defaultLang } from "../../i18n/ui";

const { lang } = Astro.props;
const language = lang ?? defaultLang;

const title = (lang: Language) => {
	switch (lang) {
		case Language.de:
			return "Ihre nächste Performance-Regression kündigt sich nicht selbst an";
		case Language.en:
			return "Your next performance regression won't announce itself";
		case Language.es:
			return "Tu próxima regresión de rendimiento no se anunciará sola";
		case Language.fr:
			return "Votre prochaine régression de performance ne s'annoncera pas toute seule";
		case Language.ja:
			return "あなたの次のパフォーマンス回帰は自ら知らせてはくれません";
		case Language.ko:
			return "당신의 다음 성능 회귀는 스스로 알리지 않습니다";
		case Language.pt:
			return "Sua próxima regressão de desempenho não vai se anunciar";
		case Language.ru:
			return "Ваша следующая регрессия производительности не объявит о себе";
		case Language.zh:
			return "你的下一次性能回归不会自己提醒你";
	}
};

const description = (lang: Language) => {
	switch (lang) {
		case Language.en:
			return "Catch it in review, or pay for it in production.";
		case Language.es:
			return "Atrápalo en la revisión, o págalo en producción.";
		case Language.fr:
			return "Attrapez-le en revue, ou payez-le en production.";
		case Language.de:
			return "Entdecken Sie es im Review, oder zahlen Sie dafür in der Produktion.";
		case Language.ja:
			return "レビューで捕まえるか、本番で代償を払うか。";
		case Language.ko:
			return "리뷰에서 잡거나, 프로덕션에서 대가를 치르세요.";
		case Language.pt:
			return "Capture na revisão, ou pague por isso em produção.";
		case Language.ru:
			return "Поймайте на ревью, или заплатите за это в продакшене.";
		case Language.zh:
			return "在代码审查中捕获，或在生产环境中付出代价。";
	}
};

const primaryCta = (lang: Language) => {
	switch (lang) {
		case Language.de:
			return "Kostenlos mit Benchmarking starten";
		case Language.en:
			return "Start benchmarking free";
		case Language.es:
			return "Empieza a hacer benchmarking gratis";
		case Language.fr:
			return "Commencez le benchmarking gratuitement";
		case Language.ja:
			return "無料でベンチマークを開始";
		case Language.ko:
			return "무료로 벤치마킹 시작";
		case Language.pt:
			return "Comece a fazer benchmarking grátis";
		case Language.ru:
			return "Начать бенчмаркинг бесплатно";
		case Language.zh:
			return "免费开始基准测试";
	}
};
---

<section class="cta-section">
	<div class="columns is-centered">
		<div class="column is-10 has-text-centered">
			<h2 class="title is-1 cta-title">{title(language)}</h2>
			<p class="subtitle is-5 cta-sub">{description(language)}</p>
			<div class="cta-buttons">
				<a class="cta-primary" href="/auth/signup">
					{primaryCta(language)}
				</a>
			</div>
		</div>
	</div>
</section>

<style>
	.cta-section {
		padding: 6rem 1.5rem 8rem;
	}

	@media screen and (min-width: 769px) {
		.cta-section {
			padding: 7rem 2rem 9rem;
		}
	}

	@media screen and (min-width: 1024px) {
		.cta-section {
			padding: 8rem 4rem 10rem;
		}
	}

	.cta-title {
		margin-bottom: 1.25rem !important;
		max-width: 900px;
		margin-left: auto !important;
		margin-right: auto !important;
	}

	.cta-sub {
		max-width: 640px;
		margin: 0 auto 2.5rem !important;
		color: var(--landing-muted);
	}

	.cta-buttons {
		display: flex;
		justify-content: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.cta-primary,
	.cta-secondary {
		display: inline-flex;
		align-items: center;
		padding: 0.75rem 1.4rem;
		border-radius: 8px;
		font-size: 1rem;
		font-weight: 500;
		text-decoration: none;
		transition: background 0.15s, border-color 0.15s, color 0.15s;
	}

	.cta-primary {
		background: var(--brand-orange);
		color: #ffffff;
		border: 1px solid var(--brand-orange);
	}

	.cta-primary:hover {
		background: var(--brand-orange-hover);
		border-color: var(--brand-orange-hover);
	}

	.cta-secondary {
		background: transparent;
		color: inherit;
		border: 1px solid rgba(0, 0, 0, 0.2);
	}

	.cta-secondary:hover {
		background: rgba(0, 0, 0, 0.04);
	}

	:global([data-theme="dark"]) .cta-secondary {
		border-color: rgba(255, 255, 255, 0.2);
	}

	:global([data-theme="dark"]) .cta-secondary:hover {
		background: rgba(255, 255, 255, 0.05);
	}
</style>
