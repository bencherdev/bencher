---
const testimonials = [
	{
		quote: "Bencher is like CodeCov for performance metrics.",
		name: "Jonathan Woollett-Light",
		github: "JonathanWoollett-Light",
		icon: "https://s3.us-east-1.amazonaws.com/public.bencher.dev/customers/JonathanWoollett-Light.jpg",
	},
	{
		quote:
			"Now that I'm starting to see graphs of performance over time automatically from tests I'm running in CI. It's like this whole branch of errors can be caught and noticed sooner.",
		name: "Price Clark",
		github: "gpwclark",
		icon: "https://s3.us-east-1.amazonaws.com/public.bencher.dev/customers/gpwclark.jpg",
	},
	{
		quote:
			"95% of the time I don't want to think about my benchmarks. But when I need to, Bencher ensures that I have the detailed historical record waiting there for me. It's fire-and-forget.",
		name: "Joe Neeman",
		github: "jneem",
		icon: "https://s3.us-east-1.amazonaws.com/public.bencher.dev/customers/jneem.jpg",
	},
];
---

<section class="landing-section engineers-section">
  <div class="columns is-centered">
    <div class="column is-10">
      <p class="landing-eyebrow">WHAT ENGINEERS SAY</p>
      <h2 class="title is-1 engineers-title">
        Performance coverage for your PRs
      </h2>

      <div class="columns is-multiline engineers-grid">
        {testimonials.map((t) => (
          <div class="column is-4">
            <figure class="engineers-card">
              <blockquote class="engineers-quote">{t.quote}</blockquote>
              <figcaption class="engineers-attribution">
                <img
                  class="engineers-avatar"
                  src={t.icon}
                  alt={t.name}
                  width="28"
                  height="28"
                  loading="lazy"
                />
                <span class="engineers-name">{t.name}</span>
                <span class="engineers-sep">·</span>
                <a
                  class="engineers-handle"
                  href={`https://github.com/${t.github}`}
                  target="_blank"
                  rel="noreferrer"
                >
                  @{t.github}
                </a>
              </figcaption>
            </figure>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Tight pair after PRComment → testimonials read as a single beat. */
  .engineers-section {
    padding-top: 1rem;
  }

  .engineers-title {
    margin-bottom: 2.5rem !important;
  }

  .engineers-grid {
    margin-top: 0;
  }

  .engineers-card {
    padding: 1.75rem;
    border-radius: 12px;
    border: 1px solid var(--landing-card-border);
    background: var(--landing-card-bg);
    height: 100%;
    display: flex;
    flex-direction: column;
    margin: 0;
  }

  .engineers-quote {
    flex: 1;
    margin: 0 0 1.5rem !important;
    font-size: 1rem;
    line-height: 1.6;
    color: inherit;
    border: none;
    padding: 0;
    background: transparent;
  }

  .engineers-attribution {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--landing-muted);
  }

  .engineers-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
    flex: 0 0 28px;
  }

  .engineers-name {
    color: inherit;
  }

  .engineers-sep {
    color: inherit;
    opacity: 0.6;
  }

  .engineers-handle {
    color: inherit;
    text-decoration: none;
  }

  .engineers-handle:hover {
    text-decoration: underline;
  }
</style>
