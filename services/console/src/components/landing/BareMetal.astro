---
const stats = [
  {
    eyebrow: "TYPICAL CI RUNNER VARIANCE",
    value: ">30%",
    tone: "bad",
    body: "Noisy shared CI runners hide real performance regressions.",
  },
  {
    eyebrow: "BENCHER BARE METAL VARIANCE",
    value: "<2%",
    tone: "good",
    body: "Dedicated bare metal hardware. When a number moves, it's real.",
  },
];
---

<section class="bare-metal-section">
  <div class="columns is-vcentered is-variable is-8">
    <div class="column is-6">
      <p class="bare-eyebrow">WHY BARE METAL</p>
      <h2 class="title is-1 bare-title">All signal. No noise.</h2>
      <p class="subtitle is-5 bare-sub">
        CI runners introduce enough noise to mask real performance regressions.
        Bencher Bare Metal isolates your benchmarks on dedicated bare metal
        hardware, so when a number changes, it means something.
      </p>
    </div>
    <div class="column is-6">
      {stats.map((stat) => (
        <div class="stat-card">
          <p class="stat-eyebrow">{stat.eyebrow}</p>
          <p class={`stat-number stat-${stat.tone}`}>{stat.value}</p>
          <p class="stat-body">{stat.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .bare-metal-section {
    padding: 4rem 1.5rem;
  }

  @media screen and (min-width: 769px) {
    .bare-metal-section {
      padding: 5rem 2rem;
    }
  }

  @media screen and (min-width: 1024px) {
    .bare-metal-section {
      padding: 5rem 4rem;
    }
  }

  @media screen and (min-width: 1216px) {
    .bare-metal-section {
      padding: 5rem 6rem;
    }
  }

  .bare-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: #888;
    margin-bottom: 1.25rem;
    line-height: 1;
  }

  .bare-title {
    margin-bottom: 1.25rem !important;
  }

  .bare-sub {
    max-width: 520px;
    color: #666;
  }

  :global([data-theme="dark"]) .bare-sub {
    color: #a0a0a0;
  }

  .stat-card {
    padding: 1.5rem 1.75rem;
    border-radius: 12px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: rgba(0, 0, 0, 0.02);
  }

  .stat-card + .stat-card {
    margin-top: 1.25rem;
  }

  :global([data-theme="dark"]) .stat-card {
    background: rgba(255, 255, 255, 0.025);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .stat-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: #888;
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .stat-number {
    font-size: 2.25rem;
    font-weight: 600;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas,
      monospace;
    margin-bottom: 0.75rem;
    line-height: 1.1;
  }

  .stat-bad {
    color: #ef4444;
  }

  .stat-good {
    color: #22c55e;
  }

  .stat-body {
    color: #666;
    line-height: 1.55;
    margin: 0;
  }

  :global([data-theme="dark"]) .stat-body {
    color: #a0a0a0;
  }
</style>
